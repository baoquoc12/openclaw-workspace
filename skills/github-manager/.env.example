# Copy file này thành .env rồi điền thông tin thật
# Lệnh nhanh:
# cp .env.example .env

# GitHub token (dạng HTTPS token)
GITHUB_TOKEN=

# GitHub username
GITHUB_USERNAME=

# Link repo GitHub dạng HTTPS
# Ví dụ: https://github.com/baoquoc12/openclaw-workspace.git
GITHUB_REPO_URL=

# Đường dẫn thư mục muốn backup
# Ví dụ: /home/ubuntu/.openclaw/workspace
URL_SOURCE_BACKUP=

# Tên thư mục backup mặc định
# Nếu user không muốn đặt tên riêng thì dùng Backup
BACKUP_NAME=Backup
